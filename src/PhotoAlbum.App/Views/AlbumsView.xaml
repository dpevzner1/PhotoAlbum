<Page x:Class="PhotoAlbum.App.Views.AlbumsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Albums"
      Background="{DynamicResource ContentBackground}">
    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,10" Background="{DynamicResource CardBackground}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Click="NewAlbumBtn_Click"
                        Style="{StaticResource PillButtonStyle}"
                        HorizontalAlignment="Right"
                        AutomationProperties.Name="Create new album">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Add" Foreground="White" Margin="0,0,6,0"/>
                        <TextBlock Text="New Album" Foreground="White"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="Albums" Style="{StaticResource TitleTextStyle}" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Smart albums row -->
        <Border DockPanel.Dock="Top" Padding="16,8,16,0">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="DuplicatesSmartAlbumBtn"
                        Click="DuplicatesSmartAlbumBtn_Click"
                        AutomationProperties.Name="Possible Duplicates smart album">
                    <Border Style="{StaticResource CardStyle}"
                            Width="160" Height="140" Cursor="Hand">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{DynamicResource SeparatorBrush}" CornerRadius="6">
                                <ui:SymbolIcon Symbol="Find" Width="40" Height="40"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{StaticResource AccentBrush}"/>
                            </Border>
                            <TextBlock Grid.Row="1" Text="Possible Duplicates"
                                       Style="{StaticResource SubtitleTextStyle}"
                                       Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </Grid>
                    </Border>
                </Button>
            </StackPanel>
        </Border>

        <!-- Album grid -->
        <ListBox x:Name="AlbumList" Padding="16"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectionMode="Single"
                 MouseDoubleClick="Album_DoubleClick"
                 KeyDown="AlbumList_KeyDown"
                 AutomationProperties.Name="Albums"
                 BorderThickness="0" Background="Transparent">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                    <DataTemplate>
                        <!-- DataContext: AlbumDisplayVm -->
                        <Border Style="{StaticResource CardStyle}"
                                Width="200" Height="210"
                                Margin="8" Cursor="Hand"
                                MouseLeftButtonUp="AlbumCard_Click"
                                AutomationProperties.Name="{Binding Album.Name}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Folder icon; tinted when hidden -->
                                <Border Grid.Row="0" CornerRadius="6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource SeparatorBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                    <Setter Property="Background" Value="#33888888"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <ui:SymbolIcon Symbol="Folder" Width="48" Height="48"
                                                       Foreground="{StaticResource AccentBrush}"/>
                                        <!-- "HIDDEN" badge -->
                                        <Border Background="#AA222222" CornerRadius="3"
                                                Padding="6,2" Margin="0,4,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="HIDDEN" Foreground="White"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <TextBlock Grid.Row="1" Text="{Binding Album.Name}"
                                           Style="{StaticResource SubtitleTextStyle}"
                                           Margin="0,6,0,0" TextTrimming="CharacterEllipsis"/>

                                <!-- Rename / Hide / Delete actions -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Margin="0,4,0,0">
                                    <Button Tag="{Binding Album}" Click="RenameAlbum_Click"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="4,2" Cursor="Hand"
                                            AutomationProperties.Name="Rename album">
                                        <TextBlock Text="Rename" FontSize="11"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    </Button>
                                    <Button Tag="{Binding Album}" Click="ToggleHideAlbum_Click"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="4,2" Cursor="Hand"
                                            AutomationProperties.Name="Hide or unhide album">
                                        <TextBlock FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Hide"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                            <Setter Property="Text" Value="Unhide"/>
                                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button>
                                    <Button Tag="{Binding Album}" Click="DeleteAlbum_Click"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="4,2" Cursor="Hand"
                                            AutomationProperties.Name="Delete album">
                                        <TextBlock Text="Delete" FontSize="11"
                                                   Foreground="{StaticResource DangerBrush}"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Page>
