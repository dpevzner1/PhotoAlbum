<Page x:Class="PhotoAlbum.App.Views.EventsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Events"
      Background="{DynamicResource ContentBackground}">
    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="16,10" Background="{DynamicResource CardBackground}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Click="NewEventBtn_Click"
                        Style="{StaticResource PillButtonStyle}"
                        HorizontalAlignment="Right"
                        AutomationProperties.Name="Create event">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Add" Foreground="White" Margin="0,0,6,0"/>
                        <TextBlock Text="New Event" Foreground="White"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="Events" Style="{StaticResource TitleTextStyle}" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
        <ListView x:Name="EventsList" Padding="16" AutomationProperties.Name="Events list">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" MinWidth="400"
                            Cursor="Hand" MouseLeftButtonUp="EventRow_Click">
                        <DockPanel>
                            <ui:SymbolIcon Symbol="Calendar" DockPanel.Dock="Left"
                                           Foreground="{StaticResource AccentBrush}"
                                           Margin="0,0,12,0"/>
                            <!-- Action buttons -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="8,0,0,0">
                                <Button Tag="{Binding}" Click="RenameEvent_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="6,2" Cursor="Hand"
                                        AutomationProperties.Name="Rename event">
                                    <TextBlock Text="Rename" FontSize="11"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                </Button>
                                <Button Tag="{Binding}" Click="DeleteEvent_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="6,2" Cursor="Hand"
                                        AutomationProperties.Name="Delete event">
                                    <TextBlock Text="Delete" FontSize="11"
                                               Foreground="{StaticResource DangerBrush}"/>
                                </Button>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" Style="{StaticResource SubtitleTextStyle}"/>
                                <TextBlock Style="{StaticResource CaptionTextStyle}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:MMM d, yyyy} – {1:MMM d, yyyy}">
                                            <Binding Path="StartUtc" FallbackValue="—"/>
                                            <Binding Path="EndUtc" FallbackValue="—"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionTextStyle}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </DockPanel>
</Page>
