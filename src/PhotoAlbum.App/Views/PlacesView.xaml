<Page x:Class="PhotoAlbum.App.Views.PlacesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      Title="Places"
      Background="{DynamicResource ContentBackground}">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,10" Background="{DynamicResource CardBackground}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Click="NewPlaceBtn_Click"
                        Style="{StaticResource PillButtonStyle}"
                        HorizontalAlignment="Right"
                        AutomationProperties.Name="Add place">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Add" Foreground="White" Margin="0,0,6,0"/>
                        <TextBlock Text="Add Place" Foreground="White"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="Places" Style="{StaticResource TitleTextStyle}" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Split: place list (left) + detail panel (right) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="220"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Place list -->
            <ListView x:Name="PlacesList" Grid.Column="0"
                      Padding="8"
                      AutomationProperties.Name="Places list"
                      SelectionChanged="PlacesList_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,6" MinWidth="200"
                                Cursor="Hand">
                            <DockPanel>
                                <ui:SymbolIcon Symbol="Map" DockPanel.Dock="Left"
                                               Foreground="{StaticResource AccentBrush}"
                                               Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <!-- Delete only — editing is in the right panel -->
                                <Button DockPanel.Dock="Right" Tag="{Binding}" Click="DeletePlace_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="6,2" Cursor="Hand" VerticalAlignment="Center"
                                        AutomationProperties.Name="Delete place">
                                    <TextBlock Text="Delete" FontSize="11"
                                               Foreground="{StaticResource DangerBrush}"/>
                                </Button>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource SubtitleTextStyle}"/>
                                    <TextBlock Style="{StaticResource CaptionTextStyle}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}Lat {0:F4}°  Lon {1:F4}°">
                                                <Binding Path="Latitude" FallbackValue="—"/>
                                                <Binding Path="Longitude" FallbackValue="—"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource SeparatorBrush}"
                          AutomationProperties.Name="Resize places list"/>

            <!-- Right panel -->
            <Grid Grid.Column="2">

                <!-- No-selection placeholder -->
                <StackPanel x:Name="MapPlaceholder"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="Map" Width="64" Height="64"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Center"/>
                    <TextBlock Text="Select a place to edit it"
                               Margin="0,12,0,0"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Edit + map panel (shown when a place is selected) -->
                <Grid x:Name="PlaceDetailPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Edit form -->
                    <Border Grid.Row="0" Padding="20,16"
                            Background="{DynamicResource CardBackground}"
                            BorderBrush="{DynamicResource SeparatorBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>

                            <!-- Name -->
                            <TextBlock Text="NAME" Style="{StaticResource MetaLabelStyle}" Margin="0,0,0,4"/>
                            <TextBox x:Name="PlaceNameBox"
                                     FontSize="14" FontWeight="SemiBold"
                                     Margin="0,0,0,14"
                                     AutomationProperties.Name="Place name"
                                     ui:ControlHelper.PlaceholderText="Place name…"/>

                            <!-- Coordinates row -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="LATITUDE" Style="{StaticResource MetaLabelStyle}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="LatBox"
                                             ui:ControlHelper.PlaceholderText="e.g. 48.8566"
                                             AutomationProperties.Name="Latitude"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="LONGITUDE" Style="{StaticResource MetaLabelStyle}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="LonBox"
                                             ui:ControlHelper.PlaceholderText="e.g. 2.3522"
                                             AutomationProperties.Name="Longitude"/>
                                </StackPanel>
                            </Grid>

                            <!-- Validation message -->
                            <TextBlock x:Name="CoordErrorText"
                                       Foreground="{StaticResource DangerBrush}"
                                       FontSize="12" Visibility="Collapsed"
                                       Margin="0,0,0,10"/>

                            <!-- Action row -->
                            <DockPanel>
                                <!-- Browse photos button -->
                                <Button DockPanel.Dock="Right" Click="BrowsePhotosBtn_Click"
                                        Margin="8,0,0,0"
                                        AutomationProperties.Name="Browse photos for this place">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Pictures" Margin="0,0,6,0"/>
                                        <TextBlock Text="Browse Photos"/>
                                    </StackPanel>
                                </Button>

                                <!-- External links -->
                                <Button DockPanel.Dock="Right" Click="OpenGoogleEarthBtn_Click"
                                        Margin="8,0,0,0"
                                        x:Name="OpenGoogleEarthBtn"
                                        Visibility="Collapsed"
                                        AutomationProperties.Name="Open in Google Earth">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Globe" Margin="0,0,6,0"/>
                                        <TextBlock Text="Google Earth"/>
                                    </StackPanel>
                                </Button>
                                <Button DockPanel.Dock="Right" Click="OpenInBrowserBtn_Click"
                                        Margin="8,0,0,0"
                                        x:Name="OpenInBrowserBtn"
                                        Visibility="Collapsed"
                                        AutomationProperties.Name="Open in Google Maps">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Map" Margin="0,0,6,0"/>
                                        <TextBlock Text="Google Maps"/>
                                    </StackPanel>
                                </Button>

                                <!-- Save -->
                                <Button Click="SavePlaceBtn_Click"
                                        Background="{StaticResource AccentBrush}"
                                        Foreground="White"
                                        AutomationProperties.Name="Save place changes">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Save" Margin="0,0,6,0"/>
                                        <TextBlock Text="Save"/>
                                    </StackPanel>
                                </Button>
                            </DockPanel>

                        </StackPanel>
                    </Border>

                    <!-- Map area -->
                    <Grid Grid.Row="1">
                        <!-- No-coordinates state -->
                        <StackPanel x:Name="NoCoordPlaceholder"
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="Collapsed">
                            <ui:SymbolIcon Symbol="MapPin" Width="48" Height="48"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           HorizontalAlignment="Center"/>
                            <TextBlock Text="Enter latitude and longitude above and press Save to pin this place on the map."
                                       Margin="0,12,0,0" MaxWidth="280" TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- WebView2 map -->
                        <wv2:WebView2 x:Name="MapWebView" Visibility="Collapsed"
                                      AutomationProperties.Name="Map view"/>
                    </Grid>
                </Grid>

            </Grid>
        </Grid>
    </DockPanel>
</Page>
