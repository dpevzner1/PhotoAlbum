<Page x:Class="PhotoAlbum.App.Views.DuplicatesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Possible Duplicates"
      Background="{DynamicResource ContentBackground}">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,12" Background="{DynamicResource CardBackground}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        x:Name="ScanBtn"
                        Click="ScanBtn_Click"
                        Style="{StaticResource PillButtonStyle}"
                        AutomationProperties.Name="Scan for duplicates">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Find" Margin="0,0,6,0"/>
                        <TextBlock Text="Scan for Duplicates"/>
                    </StackPanel>
                </Button>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource SubtitleTextStyle}" Text="Possible Duplicates"/>
                    <TextBlock x:Name="GroupCountText" Margin="12,0,0,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Progress bar (visible while scanning) -->
        <ProgressBar x:Name="ScanProgress"
                     DockPanel.Dock="Top"
                     IsIndeterminate="True"
                     Visibility="Collapsed"
                     Height="4"/>

        <!-- Info bar -->
        <Border x:Name="InfoBar" DockPanel.Dock="Top"
                Background="{DynamicResource AccentBrush}"
                Padding="16,8"
                Visibility="Collapsed">
            <TextBlock x:Name="InfoBarText" Foreground="White" FontWeight="SemiBold"/>
        </Border>

        <!-- Empty state -->
        <TextBlock x:Name="EmptyText"
                   DockPanel.Dock="Top"
                   Text="Click 'Scan for Duplicates' to analyze your library for near-identical photos."
                   Padding="32"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                   Visibility="Visible"/>

        <!-- Group list — one card per cluster -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="GroupList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="16,8" Padding="16"
                                Background="{DynamicResource CardBackground}"
                                CornerRadius="8">
                            <StackPanel>

                                <!-- Group header: similarity badge + count -->
                                <DockPanel Margin="0,0,0,12">
                                    <Border DockPanel.Dock="Left"
                                            Background="{DynamicResource AccentBrush}"
                                            CornerRadius="12" Padding="10,3"
                                            VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="{Binding SimilarityLabel}"
                                                   Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                    <TextBlock Text="{Binding GroupLabel}"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource SubtitleTextStyle}"/>
                                    <Button DockPanel.Dock="Right"
                                            HorizontalAlignment="Right"
                                            Tag="{Binding}"
                                            Click="KeepBestBtn_Click"
                                            AutomationProperties.Name="Keep the oldest photo, trash the rest">
                                        Keep Oldest · Trash Rest
                                    </Button>
                                </DockPanel>

                                <!-- Horizontally scrollable strip of thumbnails -->
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding Members}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="180" Margin="0,0,12,0">
                                                    <StackPanel>
                                                        <Border Height="160" Background="#1A000000"
                                                                CornerRadius="4"
                                                                AutomationProperties.Name="{Binding Name}">
                                                            <Image Source="{Binding ThumbnailPath}"
                                                                   Stretch="Uniform"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Name}"
                                                                   Margin="0,6,0,2"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding DateLabel}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                        <Button Margin="0,8,0,0"
                                                                Tag="{Binding}"
                                                                Click="KeepThisBtn_Click"
                                                                AutomationProperties.Name="Keep this photo, trash the others in this group">
                                                            Keep This · Trash Others
                                                        </Button>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Page>
