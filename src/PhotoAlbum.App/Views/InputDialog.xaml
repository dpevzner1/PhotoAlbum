<Window x:Class="PhotoAlbum.App.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Width="380" Height="170"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText" Grid.Row="0"
                   FontSize="{StaticResource TypeBody}"
                   Margin="0,0,0,10" TextWrapping="Wrap"/>

        <TextBox x:Name="InputBox" Grid.Row="1"
                 Margin="0,0,0,16"
                 AutomationProperties.Name="Input"
                 KeyDown="InputBox_KeyDown"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK" IsDefault="True" MinWidth="72"
                    Click="OkBtn_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" IsCancel="True" MinWidth="72"
                    Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
