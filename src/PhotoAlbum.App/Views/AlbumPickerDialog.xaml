<Window x:Class="PhotoAlbum.App.Views.AlbumPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Add to Album"
        Width="360" Height="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Choose an album:"
                   FontSize="{StaticResource TypeBody}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <ListBox Grid.Row="1"
                 x:Name="AlbumList"
                 DisplayMemberPath="Name"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 SelectionMode="Single"
                 MouseDoubleClick="AlbumList_DoubleClick"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Add" IsDefault="True" MinWidth="80"
                    Click="AddBtn_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" IsCancel="True" MinWidth="80"
                    Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
