<Page x:Class="PhotoAlbum.App.Views.AlbumDetailView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Album Detail"
      Background="{DynamicResource ContentBackground}">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Padding="16,10" Background="{DynamicResource CardBackground}">
            <DockPanel>
                <Button DockPanel.Dock="Left" Click="BackBtn_Click"
                        Style="{StaticResource NavIconButtonStyle}"
                        AutomationProperties.Name="Back to albums">
                    <ui:SymbolIcon Symbol="Back"/>
                </Button>
                <Button DockPanel.Dock="Right" Click="RenameAlbumBtn_Click"
                        Style="{StaticResource PillGhostButtonStyle}"
                        AutomationProperties.Name="Rename album">
                    <TextBlock Text="Rename"/>
                </Button>
                <TextBlock x:Name="AlbumTitle" Style="{StaticResource TitleTextStyle}"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </DockPanel>
        </Border>

        <!-- Photos in album -->
        <ScrollViewer Padding="16">
            <ItemsControl x:Name="PhotoGrid">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="160" Margin="{StaticResource ThumbnailMargin}">
                            <Border Style="{StaticResource CardStyle}" Height="160">
                                <Image Source="{Binding Thumbnail}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <!-- Remove button overlay -->
                            <Button Tag="{Binding}" Click="RemoveFromAlbum_Click"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,4,4,0" Width="24" Height="24"
                                    Background="#CC000000" BorderThickness="0"
                                    Cursor="Hand" ToolTip="Remove from album"
                                    AutomationProperties.Name="Remove from album">
                                <ui:SymbolIcon Symbol="Cancel" Foreground="White" Width="14" Height="14"/>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Page>
