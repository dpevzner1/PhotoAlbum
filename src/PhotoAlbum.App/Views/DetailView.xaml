<Page x:Class="PhotoAlbum.App.Views.DetailView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Detail"
      Background="{DynamicResource ContentBackground}"
      PreviewKeyDown="Page_KeyDown">

    <Page.InputBindings>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding ToggleFavoriteCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding SoftDeleteCommand}"/>
    </Page.InputBindings>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="MetaValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource TypeBody}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="RatingBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ── Image / Video viewer ──────────────────────────────────────── -->
        <Grid Grid.Column="0" Background="#111">
            <Grid.RowDefinitions>
                <!-- Persistent nav bar always on top -->
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Persistent top nav bar ────────────────────────────────── -->
            <Border Grid.Row="0" Background="#CC000000">
                <DockPanel Margin="8,0">
                    <Button DockPanel.Dock="Left" Click="BackBtn_Click"
                            Width="40" Height="40"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Foreground="White" VerticalAlignment="Center"
                            AutomationProperties.Name="Back to library">
                        <ui:SymbolIcon Symbol="Back" Foreground="White"/>
                    </Button>
                    <!-- counter must be docked BEFORE the fill element -->
                    <TextBlock x:Name="NavCounterText"
                               DockPanel.Dock="Right"
                               Foreground="#AAA" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock DockPanel.Dock="Left"
                               Text="{Binding Item.OriginalName, FallbackValue=''}"
                               Foreground="White" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="8,0,12,0"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>

            <!-- ── Photo / Video area ────────────────────────────────────── -->
            <Grid Grid.Row="1" x:Name="ImageViewport" SizeChanged="ImageViewport_SizeChanged"
                  ClipToBounds="True">
                <!-- Photo -->
                <ScrollViewer x:Name="ImageScroller"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              PreviewMouseWheel="ImageScroller_PreviewMouseWheel">
                    <Image x:Name="FullImage"
                           Source="{Binding FullImage}"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           AutomationProperties.Name="{Binding Item.OriginalName}">
                        <Image.LayoutTransform>
                            <RotateTransform Angle="{Binding RotationDegrees}"/>
                        </Image.LayoutTransform>
                    </Image>
                </ScrollViewer>

                <!-- Video placeholder -->
                <Border x:Name="VideoPanel" Visibility="Collapsed" Background="#000">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Play" Width="64" Height="64" Foreground="White"/>
                        <TextBlock Text="Video playback" Foreground="White" Margin="0,12,0,0"
                                   HorizontalAlignment="Center"/>
                        <Button Content="Open in System Player" Margin="0,8,0,0"
                                Click="OpenSystemPlayer_Click"
                                AutomationProperties.Name="Open video in system player"/>
                    </StackPanel>
                </Border>

                <!-- Loading overlay -->
                <Border Background="#80000000"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <ui:ProgressRing IsActive="{Binding IsLoading}" Width="48" Height="48"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Prev / Next — drawn AFTER ScrollViewer so they are on top -->
                <Button x:Name="PrevBtn" HorizontalAlignment="Left" VerticalAlignment="Center"
                        Margin="12,0,0,0" Click="PrevBtn_Click"
                        Width="44" Height="44"
                        Background="#80000000" BorderThickness="0" Cursor="Hand"
                        AutomationProperties.Name="Previous photo">
                    <ui:SymbolIcon Symbol="Previous" Foreground="White"/>
                </Button>
                <Button x:Name="NextBtn" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,12,0" Click="NextBtn_Click"
                        Width="44" Height="44"
                        Background="#80000000" BorderThickness="0" Cursor="Hand"
                        AutomationProperties.Name="Next photo">
                    <ui:SymbolIcon Symbol="Next" Foreground="White"/>
                </Button>

                <!-- ── Frosted meta bar — full width, auto-fades on hover ─ -->
                <Border x:Name="MetaOverlay"
                        VerticalAlignment="Bottom"
                        Background="#D5000000"
                        Opacity="0"
                        IsHitTestVisible="False">
                    <Grid Margin="16,10,16,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: place + albums row -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <!-- Place -->
                            <StackPanel x:Name="OverlayPlacePanel" Orientation="Horizontal"
                                        Visibility="Collapsed" Margin="0,0,0,5">
                                <ui:SymbolIcon Symbol="Map" Width="13" Height="13"
                                               Foreground="#99FFFFFF" Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                <TextBlock x:Name="OverlayPlaceText"
                                           Foreground="#DDFFFFFF" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Albums -->
                            <ItemsControl x:Name="OverlayAlbumsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#33FFFFFF" CornerRadius="10"
                                                Padding="8,3" Margin="0,0,5,0">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Folder" Width="11" Height="11"
                                                               Foreground="#CCffffff"
                                                               Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="White" FontSize="11"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Right: rating + date -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="OverlayRatingText"
                                       Text="☆☆☆☆☆"
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="16"
                                       Foreground="#FFD700"
                                       HorizontalAlignment="Right"/>
                            <TextBlock x:Name="OverlayDateText"
                                       FontSize="11" Foreground="#99FFFFFF"
                                       HorizontalAlignment="Right"
                                       Margin="0,3,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Hover triggers must live inside ImageViewport Grid -->
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="MetaOverlay"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="MetaOverlay"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>
            </Grid>
        </Grid>

        <!-- ── Metadata panel ─────────────────────────────────────────────── -->
        <Border Grid.Column="1" Background="{DynamicResource CardBackground}">
            <ScrollViewer Padding="20,20,20,20">
                <StackPanel>
                    <!-- File name -->
                    <TextBlock Text="{Binding Item.OriginalName}"
                               Style="{StaticResource SubtitleTextStyle}"
                               TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <!-- Action toolbar -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <!-- Favorite toggle -->
                        <Button Command="{Binding ToggleFavoriteCommand}"
                                Style="{StaticResource NavIconButtonStyle}"
                                ToolTip="Toggle favorite"
                                AutomationProperties.Name="Toggle favorite">
                            <ui:SymbolIcon Symbol="Favorite"/>
                        </Button>
                        <!-- Rotate 90° clockwise -->
                        <Button Command="{Binding RotateClockwiseCommand}"
                                Style="{StaticResource NavIconButtonStyle}"
                                ToolTip="Rotate 90° clockwise"
                                Margin="4,0,0,0"
                                AutomationProperties.Name="Rotate photo 90 degrees clockwise">
                            <ui:SymbolIcon Symbol="Rotate"/>
                        </Button>
                        <!-- Delete -->
                        <Button Click="DeleteBtn_Click"
                                Style="{StaticResource NavIconButtonStyle}"
                                ToolTip="Move to trash"
                                Margin="4,0,0,0"
                                Foreground="{StaticResource DangerBrush}"
                                AutomationProperties.Name="Move to trash">
                            <ui:SymbolIcon Symbol="Delete"/>
                        </Button>
                    </StackPanel>

                    <!-- Star rating -->
                    <TextBlock Text="RATING" Style="{StaticResource MetaLabelStyle}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Style="{StaticResource RatingBtnStyle}" Tag="1"
                                Click="StarBtn_Click" AutomationProperties.Name="1 star">
                            <TextBlock x:Name="Star1Text" Text="☆" FontSize="20"
                                       FontFamily="Segoe UI Symbol" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </Button>
                        <Button Style="{StaticResource RatingBtnStyle}" Tag="2"
                                Click="StarBtn_Click" AutomationProperties.Name="2 stars">
                            <TextBlock x:Name="Star2Text" Text="☆" FontSize="20"
                                       FontFamily="Segoe UI Symbol" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </Button>
                        <Button Style="{StaticResource RatingBtnStyle}" Tag="3"
                                Click="StarBtn_Click" AutomationProperties.Name="3 stars">
                            <TextBlock x:Name="Star3Text" Text="☆" FontSize="20"
                                       FontFamily="Segoe UI Symbol" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </Button>
                        <Button Style="{StaticResource RatingBtnStyle}" Tag="4"
                                Click="StarBtn_Click" AutomationProperties.Name="4 stars">
                            <TextBlock x:Name="Star4Text" Text="☆" FontSize="20"
                                       FontFamily="Segoe UI Symbol" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </Button>
                        <Button Style="{StaticResource RatingBtnStyle}" Tag="5"
                                Click="StarBtn_Click" AutomationProperties.Name="5 stars">
                            <TextBlock x:Name="Star5Text" Text="☆" FontSize="20"
                                       FontFamily="Segoe UI Symbol" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </Button>
                        <Button Style="{StaticResource RatingBtnStyle}" Tag="0"
                                Click="StarBtn_Click" Margin="8,0,0,0"
                                AutomationProperties.Name="Clear rating">
                            <ui:SymbolIcon Symbol="Clear"/>
                        </Button>
                    </StackPanel>

                    <Separator Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,16"/>

                    <!-- Date captured -->
                    <TextBlock Text="DATE" Style="{StaticResource MetaLabelStyle}"/>
                    <TextBlock Text="{Binding Item.CaptureUtc, StringFormat='{}{0:dddd, MMMM d, yyyy}', FallbackValue='Unknown'}"
                               Style="{StaticResource MetaValueStyle}"/>

                    <!-- Type -->
                    <TextBlock Text="TYPE" Style="{StaticResource MetaLabelStyle}"/>
                    <TextBlock Text="{Binding Item.MediaType}"
                               Style="{StaticResource MetaValueStyle}"/>

                    <!-- Dimensions -->
                    <TextBlock Text="DIMENSIONS" Style="{StaticResource MetaLabelStyle}"/>
                    <TextBlock Style="{StaticResource MetaValueStyle}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} × {1}">
                                <Binding Path="Item.Width" FallbackValue="—"/>
                                <Binding Path="Item.Height" FallbackValue="—"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                    <!-- Tags -->
                    <TextBlock Text="TAGS" Style="{StaticResource MetaLabelStyle}"/>
                    <ItemsControl x:Name="TagsPanel" ItemsSource="{Binding Tags}" Margin="0,0,0,6">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource AccentBrush}"
                                        CornerRadius="12" Padding="6,2" Margin="0,0,4,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="{StaticResource TypeCaption}"
                                                   Foreground="White" VerticalAlignment="Center"/>
                                        <Button Content="✕" Foreground="White" Background="Transparent"
                                                BorderThickness="0" Padding="4,0,0,0" FontSize="10"
                                                Tag="{Binding Id}"
                                                Click="RemoveTagBtn_Click"
                                                AutomationProperties.Name="{Binding Name, StringFormat='Remove tag {0}'}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- Tag picker popup -->
                    <Grid Margin="0,0,0,16">
                        <Button x:Name="AddTagBtn" Content="＋ Add tag" Click="AddTagBtn_Click"
                                HorizontalAlignment="Left"
                                AutomationProperties.Name="Add tag to photo"/>
                        <Popup x:Name="TagPickerPopup"
                               PlacementTarget="{Binding ElementName=AddTagBtn}"
                               Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                            <Border Background="{DynamicResource CardBackground}"
                                    BorderBrush="{DynamicResource SeparatorBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="4" MinWidth="200" MaxHeight="260">
                                <StackPanel>
                                    <TextBox x:Name="TagSearchBox"
                                             ui:ControlHelper.PlaceholderText="Search or create tag…"
                                             Margin="4,4,4,4"
                                             TextChanged="TagSearchBox_TextChanged"
                                             KeyDown="TagSearchBox_KeyDown"
                                             AutomationProperties.Name="Search or create tag"/>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="180">
                                        <ItemsControl x:Name="TagPickerList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding Name}"
                                                            HorizontalContentAlignment="Left"
                                                            HorizontalAlignment="Stretch"
                                                            Padding="10,6" BorderThickness="0"
                                                            Background="Transparent"
                                                            Tag="{Binding Id}"
                                                            Click="TagPickerItem_Click"
                                                            AutomationProperties.Name="{Binding Name}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <TextBlock x:Name="TagHintText"
                                               Text="Press Enter to create new tag"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Margin="10,4" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- People -->
                    <TextBlock Text="PEOPLE" Style="{StaticResource MetaLabelStyle}"/>
                    <ItemsControl x:Name="PeoplePanel" ItemsSource="{Binding People}" Margin="0,0,0,6">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <ui:SymbolIcon Symbol="Contact" Width="14" Height="14" Margin="0,0,6,0"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource MetaValueStyle}"
                                               Margin="0" VerticalAlignment="Center"/>
                                    <Button Content="✕" Background="Transparent" BorderThickness="0"
                                            Padding="6,0,0,0" FontSize="10"
                                            Tag="{Binding Id}" Click="RemovePersonBtn_Click"
                                            AutomationProperties.Name="{Binding Name, StringFormat='Remove {0}'}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- Person picker popup -->
                    <Grid Margin="0,0,0,16">
                        <Button x:Name="AddPersonBtn" Content="＋ Tag person" Click="AddPersonBtn_Click"
                                HorizontalAlignment="Left"
                                AutomationProperties.Name="Tag a person in this photo"/>
                        <Popup x:Name="PersonPickerPopup"
                               PlacementTarget="{Binding ElementName=AddPersonBtn}"
                               Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                            <Border Background="{DynamicResource CardBackground}"
                                    BorderBrush="{DynamicResource SeparatorBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="4" MinWidth="200" MaxHeight="260">
                                <StackPanel>
                                    <TextBox x:Name="PersonSearchBox"
                                             ui:ControlHelper.PlaceholderText="Search or create person…"
                                             Margin="4,4,4,4"
                                             TextChanged="PersonSearchBox_TextChanged"
                                             KeyDown="PersonSearchBox_KeyDown"
                                             AutomationProperties.Name="Search or create person"/>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="180">
                                        <ItemsControl x:Name="PersonPickerList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding Name}"
                                                            HorizontalContentAlignment="Left"
                                                            HorizontalAlignment="Stretch"
                                                            Padding="10,6" BorderThickness="0"
                                                            Background="Transparent"
                                                            Tag="{Binding Id}"
                                                            Click="PersonPickerItem_Click"
                                                            AutomationProperties.Name="{Binding Name}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <TextBlock x:Name="PersonHintText"
                                               Text="Press Enter to create new person"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Margin="10,4" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Notes -->
                    <TextBlock Text="NOTES" Style="{StaticResource MetaLabelStyle}"/>
                    <TextBox x:Name="NotesBox"
                             Text="{Binding Item.Notes, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                             AcceptsReturn="True"
                             MinHeight="80"
                             TextWrapping="Wrap"
                             LostFocus="NotesBox_LostFocus"
                             AutomationProperties.Name="Notes about this photo"/>

                    <!-- Albums -->
                    <TextBlock Text="ALBUMS" Style="{StaticResource MetaLabelStyle}"/>
                    <ItemsControl x:Name="AlbumsPanel" ItemsSource="{Binding Albums}" Margin="0,0,0,6">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SeparatorBrush}"
                                        CornerRadius="12" Padding="6,2" Margin="0,0,4,4">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Folder" Width="12" Height="12"
                                                       Margin="0,0,4,0"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="{StaticResource TypeCaption}"
                                                   VerticalAlignment="Center"/>
                                        <Button Content="✕" Background="Transparent" BorderThickness="0"
                                                Padding="4,0,0,0" FontSize="10"
                                                Tag="{Binding Id}" Click="RemoveFromAlbumBtn_Click"
                                                AutomationProperties.Name="{Binding Name, StringFormat='Remove from album {0}'}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Grid Margin="0,0,0,16">
                        <Button x:Name="AddToAlbumBtn" Content="＋ Add to album"
                                Click="AddToAlbumBtn_Click" HorizontalAlignment="Left"
                                AutomationProperties.Name="Add photo to album"/>
                        <Popup x:Name="AlbumPickerPopup"
                               PlacementTarget="{Binding ElementName=AddToAlbumBtn}"
                               Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                            <Border Background="{DynamicResource CardBackground}"
                                    BorderBrush="{DynamicResource SeparatorBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="4" MinWidth="200" MaxHeight="260">
                                <StackPanel>
                                    <TextBox x:Name="AlbumSearchBox"
                                             ui:ControlHelper.PlaceholderText="Search album…"
                                             Margin="4,4,4,4"
                                             TextChanged="AlbumSearchBox_TextChanged"
                                             AutomationProperties.Name="Search album"/>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                        <ItemsControl x:Name="AlbumPickerList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding Name}"
                                                            HorizontalContentAlignment="Left"
                                                            HorizontalAlignment="Stretch"
                                                            Padding="10,6" BorderThickness="0"
                                                            Background="Transparent"
                                                            Tag="{Binding Id}"
                                                            Click="AlbumPickerItem_Click"
                                                            AutomationProperties.Name="{Binding Name}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Place / Named location assignment -->
                    <TextBlock Text="PLACE" Style="{StaticResource MetaLabelStyle}"/>
                    <ItemsControl x:Name="PlacesPanel" ItemsSource="{Binding Places}" Margin="0,0,0,6">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <ui:SymbolIcon Symbol="MapPin" Width="14" Height="14" Margin="0,0,6,0"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource MetaValueStyle}"
                                               Margin="0" VerticalAlignment="Center"/>
                                    <Button Content="✕" Background="Transparent" BorderThickness="0"
                                            Padding="6,0,0,0" FontSize="10"
                                            Tag="{Binding Id}" Click="RemovePlaceBtn_Click"
                                            AutomationProperties.Name="{Binding Name, StringFormat='Remove place {0}'}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Grid Margin="0,0,0,16">
                        <Button x:Name="AddPlaceBtn" Content="＋ Assign place" Click="AddPlaceBtn_Click"
                                HorizontalAlignment="Left"
                                AutomationProperties.Name="Assign a place to this photo"/>
                        <Popup x:Name="PlacePickerPopup"
                               PlacementTarget="{Binding ElementName=AddPlaceBtn}"
                               Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                            <Border Background="{DynamicResource CardBackground}"
                                    BorderBrush="{DynamicResource SeparatorBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="4" MinWidth="200" MaxHeight="260">
                                <StackPanel>
                                    <TextBox x:Name="PlaceSearchBox"
                                             ui:ControlHelper.PlaceholderText="Search place…"
                                             Margin="4,4,4,4"
                                             TextChanged="PlaceSearchBox_TextChanged"
                                             AutomationProperties.Name="Search place"/>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                        <ItemsControl x:Name="PlacePickerList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding Name}"
                                                            HorizontalContentAlignment="Left"
                                                            HorizontalAlignment="Stretch"
                                                            Padding="10,6" BorderThickness="0"
                                                            Background="Transparent"
                                                            Tag="{Binding Id}"
                                                            Click="PlacePickerItem_Click"
                                                            AutomationProperties.Name="{Binding Name}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- GPS / Location -->
                    <Border x:Name="GpsSection" Visibility="Collapsed" Margin="0,0,0,16">
                        <StackPanel>
                            <Separator Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,12"/>
                            <TextBlock Text="LOCATION" Style="{StaticResource MetaLabelStyle}"/>
                            <TextBlock x:Name="GpsCoordText"
                                       Style="{StaticResource MetaValueStyle}"/>
                            <Button x:Name="ShowOnMapBtn"
                                    Click="ShowOnMapBtn_Click"
                                    AutomationProperties.Name="Show this location on Google Maps">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Map" Margin="0,0,6,0"/>
                                    <TextBlock Text="Show on Map"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- File info -->
                    <Separator Background="{DynamicResource SeparatorBrush}" Margin="0,8,0,12"/>
                    <TextBlock Text="FILE" Style="{StaticResource MetaLabelStyle}"/>
                    <TextBlock Text="{Binding CurrentFilePath}"
                               Style="{StaticResource CaptionTextStyle}"
                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="FileSizeText" Style="{StaticResource CaptionTextStyle}"
                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,2,0,0"/>

                    <!-- EXIF / Camera data -->
                    <Border x:Name="ExifSection" Visibility="Collapsed" Margin="0,12,0,0">
                        <StackPanel>
                            <Separator Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,12"/>
                            <TextBlock Text="CAMERA &amp; EXPOSURE" Style="{StaticResource MetaLabelStyle}"/>
                            <ItemsControl x:Name="ExifList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock DockPanel.Dock="Left"
                                                       Text="{Binding Label}"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Opacity="0.55" Width="90"/>
                                            <TextBlock Text="{Binding Value}"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
