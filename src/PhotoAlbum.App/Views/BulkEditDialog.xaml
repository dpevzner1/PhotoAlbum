<Window x:Class="PhotoAlbum.App.Views.BulkEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Edit Selected Photos"
        Width="480" Height="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Style="{StaticResource SubtitleTextStyle}">
                <Run Text="Edit "/>
                <Run Text="{Binding SelectionCount, Mode=OneWay}"/>
                <Run Text=" Photos"/>
            </TextBlock>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- ── Rating ──────────────────────────────────── -->
                <TextBlock Text="SET RATING" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,6"/>
                <ComboBox x:Name="RatingCombo" Width="140" HorizontalAlignment="Left" Margin="0,0,0,16"
                          AutomationProperties.Name="Rating to apply">
                    <ComboBoxItem Content="— no change —" Tag="-1" IsSelected="True"/>
                    <ComboBoxItem Content="Clear (0★)" Tag="0"/>
                    <ComboBoxItem Content="★ 1" Tag="1"/>
                    <ComboBoxItem Content="★★ 2" Tag="2"/>
                    <ComboBoxItem Content="★★★ 3" Tag="3"/>
                    <ComboBoxItem Content="★★★★ 4" Tag="4"/>
                    <ComboBoxItem Content="★★★★★ 5" Tag="5"/>
                </ComboBox>

                <!-- ── Flags ──────────────────────────────────── -->
                <TextBlock Text="FLAGS" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <CheckBox x:Name="FavoriteCheck" Content="Mark as Favorite" Margin="0,0,16,0"
                              AutomationProperties.Name="Mark selected as favorite"/>
                    <CheckBox x:Name="HiddenCheck" Content="Hide from Library"
                              AutomationProperties.Name="Hide selected from library"/>
                </StackPanel>

                <!-- ── Tags ──────────────────────────────────── -->
                <DockPanel Margin="0,0,0,6">
                    <TextBlock DockPanel.Dock="Left" Text="ADD TAGS"
                               Style="{StaticResource CaptionTextStyle}"/>
                    <TextBox x:Name="NewTagBox" DockPanel.Dock="Right"
                             ui:ControlHelper.PlaceholderText="New tag name…"
                             Width="160"
                             KeyDown="NewTagBox_KeyDown"
                             AutomationProperties.Name="Create new tag"/>
                </DockPanel>
                <Border BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1"
                        CornerRadius="4" MaxHeight="130" Margin="0,0,0,16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="TagCheckList" ItemsSource="{Binding TagChoices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}"
                                              IsChecked="{Binding IsChecked}"
                                              Padding="8,5" Margin="0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- ── People ─────────────────────────────────── -->
                <DockPanel Margin="0,0,0,6">
                    <TextBlock DockPanel.Dock="Left" Text="TAG PEOPLE"
                               Style="{StaticResource CaptionTextStyle}"/>
                    <TextBox x:Name="NewPersonBox" DockPanel.Dock="Right"
                             ui:ControlHelper.PlaceholderText="New person name…"
                             Width="160"
                             KeyDown="NewPersonBox_KeyDown"
                             AutomationProperties.Name="Create new person"/>
                </DockPanel>
                <Border BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1"
                        CornerRadius="4" MaxHeight="110" Margin="0,0,0,16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="PersonCheckList" ItemsSource="{Binding PersonChoices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}"
                                              IsChecked="{Binding IsChecked}"
                                              Padding="8,5" Margin="0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- ── Location / Place ───────────────────────── -->
                <DockPanel Margin="0,0,0,6">
                    <TextBlock DockPanel.Dock="Left" Text="SET LOCATION"
                               Style="{StaticResource CaptionTextStyle}"/>
                    <TextBox x:Name="NewPlaceBox" DockPanel.Dock="Right"
                             ui:ControlHelper.PlaceholderText="New place name…"
                             Width="160"
                             KeyDown="NewPlaceBox_KeyDown"
                             AutomationProperties.Name="Create new place"/>
                </DockPanel>
                <Border BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1"
                        CornerRadius="4" MaxHeight="110" Margin="0,0,0,16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="PlaceCheckList" ItemsSource="{Binding PlaceChoices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}"
                                              IsChecked="{Binding IsChecked}"
                                              Padding="8,5" Margin="0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Status -->
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource CaptionTextStyle}"
                           Foreground="{StaticResource AccentBrush}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Click="DeleteBtn_Click"
                    Foreground="{StaticResource DangerBrush}"
                    Margin="0,0,8,0"
                    AutomationProperties.Name="Move all selected to trash">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Delete" Margin="0,0,4,0"/>
                    <TextBlock Text="Trash All"/>
                </StackPanel>
            </Button>
            <Button Content="Cancel" IsCancel="True" Margin="0,0,8,0"
                    AutomationProperties.Name="Cancel"/>
            <Button Click="ApplyBtn_Click"
                    Background="{StaticResource AccentBrush}" Foreground="White"
                    IsDefault="True" MinWidth="80"
                    AutomationProperties.Name="Apply changes">
                Apply
            </Button>
        </StackPanel>
    </Grid>
</Window>
